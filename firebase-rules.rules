/*
 * ============================================================
 *  قواعد أمان Cloud Firestore — نظام الاستمارات الذكي
 * ============================================================
 *
 *  مكان النشر:
 *    Firebase Console → Firestore Database → تبويب Rules
 *    الصق هذا المحتوى بالكامل ثم اضغط "Publish"
 *
 *  ⚠️ بعد النشر تأكد من تغيير وضع قواعد الإنتاج
 *     من القائمة المنسدلة (لا تتركه على Test Mode)
 * ============================================================
 */

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    /* ==========================================================
     *  مجموعة المستخدمين  users/{userId}
     * ==========================================================
     *
     *  تحتوي على:
     *    name, email, role, photoURL, assignedForms, createdAt
     *
     *  من يقرأ:  أي مستخدم مسجل (المدير لعرض القائمة،
     *            البناء لعرض المستشارين)
     *
     *  من يكتب:  المدير (لتغيير الأدوار وتعيين الاستمارات)
     *            أو صاحب الحساب نفسه (أول تسجيل يدخل)
     * ========================================================== */
    match /users/{userId} {

      allow read: if request.auth != null;

      allow write: if request.auth != null && (
        request.auth.uid == userId ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
    }


    /* ==========================================================
     *  مجموعة الاستمارات  forms/{formId}
     * ==========================================================
     *
     *  تحتوي على:
     *    title, description, published, questions,
     *    assignedCounselors, evaluationRanges,
     *    postSubmissionMessage, responseCount,
     *    createdAt, updatedAt
     *
     *  القراءة:
     *    أي مستخدم مسجل — لأن الجميع يحتاجون الوصول:
     *    - المدير: لإدارة الاستمارات
     *    - المستشار: لعرض المخصصة له
     *    - المستخدم العادي: لملء الاستمارة العامة
     *
     *  الإنشاء:
     *    المدير فقط
     *
     *  التعديل:
     *    - المدير: يعدل أي حقل (العنوان، الأسئلة، إلخ)
     *    - غير المدير: يُسمح فقط بزيادة responseCount بمقدار 1
     *      (يحدث تلقائياً عند إرسال المستخدم للاستمارة)
     *
     *  الحذف:
     *    المدير فقط
     * ========================================================== */
    match /forms/{formId} {

      allow read: if request.auth != null;

      allow create: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';

      allow update: if request.auth != null && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
        ||
        (
          // غير المدير: يُسمح فقط بتعديل حقل responseCount
          // والتأكد أنه زاد بمقدار 1 فقط (لا يمكن التلاعب)
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['responseCount'])
          &&
          request.resource.data.responseCount == resource.data.responseCount + 1
        )
      );

      allow delete: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }


    /* ==========================================================
     *  مجموعة الردود  responses/{responseId}
     * ==========================================================
     *
     *  تحتوي على:
     *    formId, respondentUid, respondentEmail, respondentName,
     *    answers[], totalPoints, evaluationResult{},
     *    createdAt
     *
     *  الإنشاء:
     *    أي مستخدم مسجل (يملأ استمارة)
     *    لا يُسمح بإنشاء رد بدون تسجيل دخول
     *
     *  القراءة — ثلاث حالات مرخصة:
     *
     *    ١. المدير:
     *       يرى جميع الردود في جميع الاستمارات
     *
     *    ٢. المستشار:
     *       يرى فقط ردود الاستمارات المخصصة له
     *       (التحقق: هل UID الخاص بالمستشار موجود
     *        داخل مصفوفة assignedCounselors في الاستمارة؟)
     *
     *    ٣. المستخدم العادي:
     *       يرى فقط ردوده هو (respondentUid == uid)
     *       لعرض السجل الشخصي وتحليل النتائج
     *
     *  الحذف:
     *    المدير فقط (عند حذف استمارة يتم حذف ردودها)
     *
     *  التعديل: ممنوع — لا يمكن تعديل رد بعد إرساله
     *    (إذا احتجت تعديل بيانات، احذف وأنشئ جديداً)
     * ========================================================== */
    match /responses/{responseId} {

      allow create: if request.auth != null;

      allow read: if request.auth != null && (
        // ١. المدير يرى كل شيء
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
        ||
        // ٢. المستشار يرى ردود استماراته فقط
        request.auth.uid in get(/databases/$(database)/documents/forms/$(resource.data.formId)).data.assignedCounselors
        ||
        // ٣. المستخدم يرى ردوده فقط
        resource.data.respondentUid == request.auth.uid
      );

      allow delete: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';

      // لا يُسمح بالتعديل أبداً — الردود ثابتة بعد الإرسال
      allow update: if false;
    }
  }
}
