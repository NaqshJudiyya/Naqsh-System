rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // 1. مجموعة المستخدمين
    match /users/{userId} {
      allow read: if request.auth != null;
      
      allow write: if request.auth != null && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
        (resource == null && request.auth.uid == userId) ||
        (resource != null && request.auth.uid == userId && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role']))
      );
    }

    // 2. مجموعة الاستمارات
    match /forms/{formId} {
      allow read: if request.auth != null;
      allow create, delete: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
      
      allow update: if request.auth != null && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
        (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['responseCount']) &&
          request.resource.data.responseCount == resource.data.responseCount + 1
        )
      );
    }

    // 3. مجموعة الردود
    match /responses/{responseId} {
      // إلزام المستخدم بأن يكون الـ respondentUid هو نفسه الـ UID بتاعه
      allow create: if request.auth != null && request.resource.data.respondentUid == request.auth.uid;

      allow read: if request.auth != null && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
        request.auth.uid in get(/databases/$(database)/documents/forms/$(resource.data.formId)).data.assignedCounselors ||
        resource.data.respondentUid == request.auth.uid
      );

      allow delete: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
      allow update: if false;
    }
  }
}
